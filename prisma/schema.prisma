// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ConnectedAccount {
  id             String         @id @default(cuid())
  provider       String // "GOOGLE" | "OUTLOOK" | "CALDAV"
  email          String
  accessToken    String
  refreshToken   String?
  expiresAt      DateTime
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  calendars      CalendarFeed[]
  mailAccounts   MailAccount[]
  // CalDAV specific fields
  caldavUrl      String? // Base URL for CalDAV server
  caldavUsername String? // Username for Basic Auth

  // User relationship
  userId       String?
  user         User?          @relation(fields: [userId], references: [id])
  TaskProvider TaskProvider[]

  // Account identity is scoped by server URL for CalDAV so a user can connect
  // multiple CalDAV servers (even with the same username). For OAuth providers
  // caldavUrl is null; the migration creates this index with NULLS NOT DISTINCT
  // (a Prisma-schema-unexpressible Postgres feature) so null URLs are treated as
  // equal and OAuth stays one-account-per-(userId, provider, email). See the
  // migration `20260622130000_caldav_account_unique_by_server_url` and issue #145.
  //
  // IMPORTANT: provision the database with `prisma migrate deploy` (as this repo
  // does), NOT `prisma db push`. `db push` builds this index from the schema DSL,
  // which cannot express NULLS NOT DISTINCT, so it would treat null caldavUrl as
  // distinct and silently allow duplicate OAuth (Google/Outlook) accounts.
  @@unique([userId, provider, email, caldavUrl], map: "ConnectedAccount_userId_provider_email_caldavUrl_key")
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                    String                 @id @default(cuid())
  name                  String?
  email                 String?                @unique
  emailVerified         DateTime?
  image                 String?
  role                  String                 @default("user") // Possible values: "user", "admin"
  subscription          Subscription?
  accounts              Account[]
  sessions              Session[]
  calendars             CalendarFeed[]
  autoScheduleSettings  AutoScheduleSettings?
  userSettings          UserSettings?
  calendarSettings      CalendarSettings?
  notificationSettings  NotificationSettings?
  customizationSettings UserCustomization?
  integrationSettings   IntegrationSettings?
  dataSettings          DataSettings?
  schedulingPreferences SchedulingPreferences?
  energyProfileWindows  EnergyProfileWindow[]
  aiSettings            AISettings?
  aiOAuthConnections    AIOAuthConnection[]
  aiOAuthStates         AIOAuthState[]
  aiConversations       AiConversation[]
  aiMessages            AiMessage[]
  agentMemories         AgentMemory[]
  aiUsage               AiUsage[]
  connectorSettings     ConnectorSettings?
  timeEntries           TimeEntry[]
  scheduledBlocks       ScheduledBlock[]
  focusSessions         FocusSession[]
  focusStats            FocusStats?
  tasks                 Task[]
  projects              Project[]
  connectedAccounts     ConnectedAccount[]
  mailAccounts          MailAccount[]
  tags                  Tag[]
  JobRecord             JobRecord[]
  taskProviders         TaskProvider[]
  TaskChange            TaskChange[]
  PasswordReset         PasswordReset[]
  boards                Board[]
  savedViews            SavedView[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CalendarFeed {
  id                String            @id @default(uuid())
  name              String
  url               String? // Optional for local calendars
  type              String // "LOCAL", "GOOGLE", "OUTLOOK", "CALDAV"
  color             String? // Add back color field
  enabled           Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  lastSync          DateTime?
  syncToken         String? // For incremental sync
  error             String?
  channelId         String? // Google Calendar webhook channel ID
  resourceId        String? // Google Calendar webhook resource ID
  channelExpiration DateTime? // When the webhook expires
  events            CalendarEvent[]
  userId            String?
  user              User?             @relation(fields: [userId], references: [id])
  accountId         String?
  account           ConnectedAccount? @relation(fields: [accountId], references: [id])
  // CalDAV specific fields
  caldavPath        String? // Path to the specific calendar on the server
  ctag              String? // CalDAV collection tag for change detection
  webhooks          CalendarWebhook[]

  @@index([accountId])
}

model CalendarWebhook {
  id             String       @id @default(cuid())
  provider       String
  feedId         String
  feed           CalendarFeed @relation(fields: [feedId], references: [id], onDelete: Cascade)
  channelId      String?
  subscriptionId String?
  resourceId     String?
  expiration     DateTime
  clientState    String?
  channelToken   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([provider, feedId])
  @@index([channelId])
  @@index([subscriptionId])
}

model CalendarEvent {
  id              String       @id @default(uuid())
  feedId          String
  feed            CalendarFeed @relation(fields: [feedId], references: [id], onDelete: Cascade)
  externalEventId String? // External Calendar Event ID (Google, Outlook, etc.)
  title           String
  description     String?
  start           DateTime
  end             DateTime
  location        String?
  isRecurring     Boolean      @default(false)
  recurrenceRule  String?
  allDay          Boolean      @default(false)
  status          String?
  sequence        Int?
  created         DateTime?
  lastModified    DateTime?
  organizer       Json? // Stored as JSON { name?: string, email: string }
  attendees       Json? // Stored as JSON array of { name?: string, email: string, status?: string }
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // New fields for hybrid approach
  isMaster         Boolean         @default(false) // True if this is a master event
  masterEventId    String? // Reference to the master event for instances
  masterEvent      CalendarEvent?  @relation("EventInstances", fields: [masterEventId], references: [id], onDelete: Cascade)
  instances        CalendarEvent[] @relation("EventInstances")
  recurringEventId String? // Google Calendar's recurring event ID

  @@index([feedId])
  @@index([start, end])
  @@index([externalEventId])
  @@index([masterEventId])
  @@index([recurringEventId])
}

model MailAccount {
  id                   String            @id @default(cuid())
  userId               String
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider             MailProvider
  address              String
  encryptedCredentials String?
  connectionRef        String?
  connection           ConnectedAccount? @relation(fields: [connectionRef], references: [id], onDelete: SetNull)
  status               MailAccountStatus @default(ACTIVE)
  syncCursor           String?
  lastSyncAt           DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  messages             MailMessage[]

  @@unique([userId, provider, address])
  @@index([userId])
  @@index([connectionRef])
  @@index([status])
}

model MailMessage {
  id          String      @id @default(cuid())
  accountId   String
  account     MailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  externalId  String
  threadId    String?
  fromName    String?
  fromAddress String?
  toAddresses Json
  subject     String
  snippet     String
  date        DateTime
  isRead      Boolean     @default(false)
  isArchived  Boolean     @default(false)
  labels      Json
  bodyHtml    String?     @db.Text
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([accountId, externalId])
  @@index([accountId, date])
  @@index([accountId, isRead, isArchived])
}

model Project {
  id               String            @id @default(cuid())
  name             String
  description      String?
  color            String?
  icon             String?
  progress         Int               @default(0)
  status           String            @default("active") // enum: 'active', 'archived'
  tasks            Task[]
  taskListMappings TaskListMapping[]

  // External sync fields
  externalId     String?
  externalSource String?
  lastSyncedAt   DateTime?

  // User relationship
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@index([externalId, externalSource])
}

model Task {
  id          String  @id @default(cuid())
  title       String
  description String?
  status      String // enum: 'todo', 'in_progress', 'completed'

  // Time Management
  dueDate       DateTime?
  startDate     DateTime? // When the task becomes active
  duration      Int? // estimated duration in minutes
  priority      String? // enum: 'high', 'medium', 'low', 'none'
  energyLevel   String? // enum: 'high', 'medium', 'low'
  preferredTime String? // enum: 'morning', 'afternoon', 'evening'

  // Smart scheduling fields
  energyRequired       SchedulingEnergyLevel  @default(MEDIUM)
  estimatedMinutes     Int?
  estOptimistic        Int?
  estLikely            Int?
  estPessimistic       Int?
  actualMinutes        Int?
  actualFocusedMinutes Int                    @default(0)
  estimateDelta        Int?
  optimisticDelta      Int?
  likelyDelta          Int?
  pessimisticDelta     Int?
  minChunkMinutes      Int?
  maxChunkMinutes      Int?
  deadline             DateTime?
  priorityLevel        SchedulingTaskPriority @default(MEDIUM)
  contextTag           String?
  isFrozen             Boolean                @default(false)
  dependsOnId          String?
  dependsOn            Task?                  @relation("TaskDependencies", fields: [dependsOnId], references: [id], onDelete: SetNull)
  dependents           Task[]                 @relation("TaskDependencies")
  autoScheduled        Boolean                @default(false)

  // Auto-scheduling
  isAutoScheduled Boolean   @default(false)
  scheduleLocked  Boolean   @default(false)
  scheduledStart  DateTime?
  scheduledEnd    DateTime?
  scheduleScore   Float?
  lastScheduled   DateTime?
  postponedUntil  DateTime? // New field for postponing tasks

  // Calendar block push
  blockEventId String? // Google Calendar event ID of the pushed block
  blockFeedId  String? // Calendar feed ID where event is stored
  blockDirty   Boolean @default(false) // Push failed, needs retry

  // Organization
  tags Tag[]

  // Recurrence
  isRecurring       Boolean   @default(false)
  recurrenceRule    String?
  lastCompletedDate DateTime?
  completedAt       DateTime? // When the task was marked as completed

  // External Integration
  externalTaskId String?
  source         String?
  lastSyncedAt   DateTime?

  // Enhanced sync fields
  externalListId    String? // The external list/folder ID this task belongs to
  externalCreatedAt DateTime? // When the task was created in the external system
  externalUpdatedAt DateTime? // When the task was last updated in the external system
  syncStatus        String? // 'synced', 'pending', 'error', etc.
  syncError         String? // Error message if sync failed
  syncHash          String? // Hash of task data for detecting changes
  skipSync          Boolean   @default(false) // Flag to skip syncing this task

  // Change tracking relation
  changes         TaskChange[]
  timeEntries     TimeEntry[]
  scheduledBlocks ScheduledBlock[]
  focusSessions   FocusSession[]

  // User relationship
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  // Boards: a task can live on one board in one column. These are additive and
  // do NOT affect the scheduling engine — a board task is the same task the
  // auto-scheduler works with. `properties` is reserved for future custom
  // fields. boardPosition is a fractional index (see @/lib/board-position).
  boardId       String?
  board         Board?       @relation(fields: [boardId], references: [id], onDelete: SetNull)
  boardColumnId String?
  boardColumn   BoardColumn? @relation(fields: [boardColumnId], references: [id], onDelete: SetNull)
  boardPosition Float?
  properties    Json?

  @@index([status])
  @@index([dueDate])
  @@index([startDate])
  @@index([priority])
  @@index([projectId])
  @@index([boardId])
  @@index([boardColumnId])
  @@index([isRecurring])
  @@index([isAutoScheduled])
  @@index([scheduledStart, scheduledEnd])
  @@index([externalTaskId])
  @@index([source])
  @@index([postponedUntil])
  @@index([deadline])
  @@index([energyRequired])
  @@index([priorityLevel])
  @@index([contextTag])
  @@index([isFrozen])
  @@index([dependsOnId])
  @@index([autoScheduled])
  @@index([userId])
  @@index([externalTaskId, source])
  @@index([syncStatus])
  @@index([externalListId])
  @@index([blockDirty, userId])
  @@index([blockFeedId])
}

model TimeEntry {
  id        String          @id @default(cuid())
  taskId    String
  task      Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?           @relation(fields: [userId], references: [id])
  startedAt DateTime
  endedAt   DateTime?
  source    TimeEntrySource @default(timer)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([taskId])
  @@index([userId, startedAt])
  @@index([source])
}

model ScheduledBlock {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  start      DateTime
  end        DateTime
  chunkIndex Int      @default(0)
  chunkCount Int      @default(1)
  isFrozen   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([taskId, chunkIndex])
  @@index([userId, start])
  @@index([taskId])
  @@index([start, end])
}

model FocusSession {
  id                 String           @id @default(cuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId             String?
  task               Task?            @relation(fields: [taskId], references: [id], onDelete: SetNull)
  mode               FocusSessionMode
  plannedMinutes     Int?
  elapsedMinutes     Int              @default(0)
  completed          Boolean          @default(false)
  abandoned          Boolean          @default(false)
  // Server-truth timing. An active session has endedAt = null. pausedTotalSeconds
  // accumulates completed pause spans; pausedAt is set while currently paused.
  startedAt          DateTime
  endedAt            DateTime?
  pausedAt           DateTime?
  pausedTotalSeconds Int              @default(0)
  source             String           @default("web")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([userId, startedAt])
  @@index([userId, endedAt])
  @@index([taskId])
  @@index([mode])
  @@index([completed])
}

model FocusStats {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  focusScore      Int       @default(0)
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lifetimeMinutes Int       @default(0)
  lastFocusDate   DateTime?
  updatedAt       DateTime  @updatedAt
  createdAt       DateTime  @default(now())
}

model Board {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  icon       String? // emoji
  position   Float         @default(0)
  // "manual" columns, or auto-group by status | priority | project | tag.
  groupBy    String        @default("manual")
  columns    BoardColumn[]
  tasks      Task[]
  savedViews SavedView[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([userId])
}

model BoardColumn {
  id         String   @id @default(cuid())
  boardId    String
  board      Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name       String
  color      String?
  position   Float    @default(0)
  // For auto-grouped boards, the derived value this column maps to (e.g. a
  // status or priority value). Null for manual columns.
  mappingKey String?
  tasks      Task[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([boardId])
}

model SavedView {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  boardId   String?
  board     Board?   @relation(fields: [boardId], references: [id], onDelete: SetNull)
  // table | board | list | timeline | calendar | gallery
  type      String
  groupBy   String?
  filters   Json?
  sort      Json?
  position  Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([boardId])
}

model EnergyProfileWindow {
  id          String                @id @default(cuid())
  userId      String
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek   Int // 0-6, where 0 is Sunday
  startTime   String // HH:mm
  endTime     String // HH:mm
  energyLevel SchedulingEnergyLevel
  sortOrder   Int                   @default(0)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([userId, dayOfWeek, startTime, endTime])
  @@index([userId, dayOfWeek, sortOrder])
  @@index([energyLevel])
}

model SchedulingPreferences {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workHours            Json?
  bufferMinutes        Int      @default(15)
  maxDeepWorkPerDay    Int      @default(180)
  minBreakMinutes      Int      @default(15)
  autoRescheduleOnMiss Boolean  @default(true)
  enableBodyDoubling   Boolean  @default(false)
  enableTaskBatching   Boolean  @default(true)
  hardStopTime         String   @default("18:00")
  bufferMultiplier     Float    @default(1.3)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
}

model AISettings {
  id                    String     @id @default(cuid())
  userId                String     @unique
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider              AIProvider @default(NONE)
  encryptedApiKey       String?
  encryptedAnthropicKey String?
  encryptedOpenAIKey    String?
  encryptedGrokKey      String?
  encryptedGlmKey       String?
  customUrl             String?
  model                 String?
  soulPreset            String     @default("business")
  allowParseTasks       Boolean    @default(true)
  allowReorder          Boolean    @default(false)
  allowSuggestEnergy    Boolean    @default(true)
  allowFullAuto         Boolean    @default(false)
  requestTimeoutSeconds Int        @default(20)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@index([userId])
  @@index([provider])
}

model AgentMemory {
  id         String            @id @default(cuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind       AgentMemoryKind
  content    String
  source     AgentMemorySource @default(chat)
  weight     Float             @default(1)
  createdAt  DateTime          @default(now())
  lastUsedAt DateTime          @default(now())

  @@index([userId, lastUsedAt])
  @@index([userId, weight])
}

model AiUsage {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  yearMonth   String
  actionCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, yearMonth])
  @@index([yearMonth])
}

// OAuth credentials are kept separate from AISettings so API-key configuration
// can remain intact when a user connects or disconnects an OAuth-capable custom
// provider. Tokens are encrypted application-side before being written here.
model AIOAuthConnection {
  id                    String     @id @default(cuid())
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider              AIProvider
  encryptedAccessToken  String
  encryptedRefreshToken String?
  tokenType             String?
  scope                 String?
  expiresAt             DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

// Short-lived, one-use authorization-code state. The state secret is stored as
// a hash while the PKCE verifier is encrypted because it must be sent to the
// token endpoint after the browser returns.
model AIOAuthState {
  id                    String     @id @default(cuid())
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider              AIProvider
  stateHash             String     @unique
  encryptedCodeVerifier String
  redirectUri           String
  expiresAt             DateTime
  createdAt             DateTime   @default(now())

  @@index([userId, provider])
  @@index([expiresAt])
}

model AiConversation {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String      @default("New chat")
  messages  AiMessage[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId, updatedAt])
}

model AiMessage {
  id              String         @id @default(cuid())
  conversationId  String
  conversation    AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            String
  content         String
  toolName        String?
  toolPayload     Json?
  requiresConfirm Boolean        @default(false)
  createdAt       DateTime       @default(now())

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
}

model ConnectorSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash           String?  @unique
  tokenPreview        String?
  webhookUrl          String?
  webhookSchedule     Boolean  @default(false)
  webhookTaskComplete Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([tokenHash])
}

model Tag {
  id    String  @id @default(cuid())
  name  String
  color String?
  tasks Task[]

  // User relationship
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@unique([name, userId])
  @@index([name])
  @@index([userId])
}

model AutoScheduleSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Work Hours
  workDays      String @default("[]") // JSON string of numbers 0-6
  workHourStart Int // 0-23
  workHourEnd   Int // 0-23

  // Preferences
  selectedCalendars String @default("[]") // JSON string of calendar IDs
  bufferMinutes     Int    @default(15)

  // Energy Level Mappings
  highEnergyStart   Int? // 0-23
  highEnergyEnd     Int? // 0-23
  mediumEnergyStart Int? // 0-23
  mediumEnergyEnd   Int? // 0-23
  lowEnergyStart    Int? // 0-23
  lowEnergyEnd      Int? // 0-23

  // Project Settings
  groupByProject Boolean @default(false)

  // Calendar block push settings
  pushTasksToCalendar Boolean @default(false) // Enable pushing task blocks to calendar
  pushTasksFeedId     String? // ID of target CalendarFeed (must be GOOGLE type)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model UserSettings {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme        String   @default("dark") // "light", "dark", "system"
  defaultView  String   @default("week") // "day", "week", "month", "agenda"
  timeZone     String
  weekStartDay String   @default("sunday") // "monday", "sunday"
  timeFormat   String   @default("12h") // "12h", "24h"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model CalendarSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultCalendarId   String?
  workingHoursEnabled Boolean  @default(true)
  workingHoursStart   String   @default("09:00") // HH:mm format
  workingHoursEnd     String   @default("17:00") // HH:mm format
  workingHoursDays    String   @default("[1,2,3,4,5]") // JSON string of numbers 0-6
  defaultDuration     Int      @default(60) // minutes
  defaultColor        String   @default("#3b82f6")
  defaultReminder     Int      @default(30) // minutes
  refreshInterval     Int      @default(5) // minutes
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
}

model NotificationSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailNotifications    Boolean  @default(true)
  dailyEmailEnabled     Boolean  @default(true) // Controls whether the user receives daily email updates
  eventInvites          Boolean  @default(true)
  eventUpdates          Boolean  @default(true)
  eventCancellations    Boolean  @default(true)
  eventReminders        Boolean  @default(true)
  defaultReminderTiming String   @default("[30]") // JSON string of minutes before event
  webPushEnabled        Boolean  @default(false)
  webPushSubscription   Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
}

model UserCustomization {
