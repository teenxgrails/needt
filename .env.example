# Database Configuration
DATABASE_URL="postgresql://fluid:fluid@db:5432/fluid_calendar"
DIRECT_URL="postgresql://fluid:fluid@db:5432/fluid_calendar"

# NextAuth Configuration
# Use domain in production, localhost for development
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-min-32-chars"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

CRON_SECRET="replace-with-random-cron-secret"

# Async calendar sync and realtime updates
REDIS_URL="redis://localhost:6379"
# Defaults to NEXTAUTH_URL when omitted.
WEBHOOK_BASE_URL="http://localhost:3000"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID="common"

ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
AI_CUSTOM_URL=""
AI_ENCRYPTION_KEY=""
NEEDT_AI_API_KEY=""
NEEDT_AI_MODEL="deepseek-chat"
NEEDT_AI_BASE_URL="https://api.deepseek.com/v1"
NEEDT_AI_MONTHLY_ACTION_CAP="300"
NEEDT_AI_LIFETIME_ACTION_CAP="3000"

# Creem billing (optional; the app stays on Free when omitted)
